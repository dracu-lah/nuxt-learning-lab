  "faq": {
    "q1": {
      "q": "What is Nuxt Learning Lab?",
      "a": "A reference project that demonstrates auth, i18n, RTL, charts, and most other patterns you'll meet in a real Nuxt app."
    },
    "q2": {
      "q": "Do I need a credit card to start?",
      "a": "No. The Free plan needs no card. You can upgrade at any time from the dashboard."
    },
    "q3": {
      "q": "Is my data secure?",
      "a": "All data is encrypted in transit and at rest. Pro and Business plans add audit logs and SSO."
    },
    "q4": {
      "q": "Do you support multiple languages?",
      "a": "Yes. The UI is available in English, Spanish, and Arabic, with full right-to-left support."
    },
    "q5": {
      "q": "How do I get help?",
      "a": "Free users have community support. Pro and Business plans include priority email and chat."
    }
  }
